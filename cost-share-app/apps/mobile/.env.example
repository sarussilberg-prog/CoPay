# Copy to .env — local dev only (project drxfbicunusmipdgbgdk).
# Production EAS: copy this file to .env.production with jfqxjjjbpxbwwvoygahu keys (see docs/SSOT/SUPABASE_ENVIRONMENTS.md).
EXPO_PUBLIC_SUPABASE_URL=https://drxfbicunusmipdgbgdk.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_dev_publishable_key

EXPO_PUBLIC_WEB_APP_URL=https://kupa.pro
# Required on Android for Google sign-in (native picker in bottom sheet — WebView OAuth is blocked by Google).
# Web application OAuth client ID from Google Cloud (NOT Android / Installed).
# Also set the same Client ID in Supabase → Auth → Google, and register Android OAuth + SHA-1 (see PLAY_STORE_ANDROID.md).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Supabase Auth → URL Configuration → Redirect URLs (dev + prod) — required for iOS / web / fallback OAuth:
#   com.kupay.mobile://auth/callback
#   exp://<LAN_IP>:8081/--/auth/callback  (Expo Go only)
# If this list is missing the native URI, Supabase redirects to Site URL (EXPO_PUBLIC_WEB_APP_URL) instead.
EXPO_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/idXXXXXXXX
EXPO_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.kupay.mobile
EXPO_PUBLIC_SUPPORT_EMAIL=sarussilberg@gmail.com
